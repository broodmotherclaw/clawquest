# ============================================
# HexClaw Environment Configuration
# Copy this file to .env and fill in your values
# ============================================

# ============================================
# Database Configuration (PostgreSQL)
# ============================================
POSTGRES_USER=hexclaw
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=hexclaw
DATABASE_URL=postgresql://hexclaw:your_secure_password_here@postgres:5432/hexclaw?schema=public

# If you change POSTGRES_PASSWORD, update DATABASE_URL accordingly.

# ============================================
# Backend Configuration
# ============================================
BACKEND_PORT=3001

# URL where the frontend is hosted (for CORS)
# In production, use your domain or server IP
FRONTEND_URL=http://localhost

# Secret key for OpenClaw Bot authentication
# Generate a secure random string for production
OPENCLAW_BOT_SECRET=your_secret_key_here_change_in_production
SHARED_SECRET=your_shared_secret_here_change_in_production
# Temporary troubleshooting switch (1 = disable bot auth checks; do not use in normal production)
OPENCLAW_DISABLE_BOT_AUTH=0

# ============================================
# Frontend Configuration
# ============================================
FRONTEND_PORT=80

# API URL for the frontend to connect to
# In production with nginx proxy, use /api/ or empty
# For direct backend access, use: http://your-server-ip:3001
VITE_API_URL=/api

# ============================================
# Docker Configuration
# ============================================
# COMPOSE_PROJECT_NAME=hexclaw

# ============================================
# SSL/TLS Configuration (for future HTTPS setup)
# ============================================
# Uncomment and configure when using HTTPS
# SSL_CERT_PATH=/path/to/cert.pem
# SSL_KEY_PATH=/path/to/key.pem

# ============================================
# AI Validation Provider Configuration
# ============================================
# Choose your AI provider for answer validation
# Options: "glm", "openai", "anthropic", "local"
AI_PROVIDER=glm

# GLM-4 API Key (from z.ai / bigmodel.cn)
# Get your key at: https://open.bigmodel.cn/
GLM_API_KEY=your_glm_api_key_here

# Alternative: OpenAI API Key (optional)
# OPENAI_API_KEY=your_openai_key_here

# Alternative: Anthropic Claude API Key (optional)
# ANTHROPIC_API_KEY=your_anthropic_key_here
